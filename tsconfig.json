{
    "extends": "@box/frontend/ts/tsconfig",
    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "compilerOptions": {
        "lib": ["DOM", "ES2020"],
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["classnames", "draft-js", "enzyme", "jest", "lodash", "react", "react-dom", "react-redux", "uuid"]
    }
}
